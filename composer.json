{
    "name": "otavio-araujo/filament-smart-cep",
    "description": "A FilamentPHP plugin that validates Brazilian postal codes (CEP) and automatically fills address fields (street, neighborhood, city, state, country) using ViaCEP as the primary source, with multiple API fallbacks for reliability.",
    "keywords": [
        "otavio-araujo",
        "laravel",
        "filamentphp",
        "filament-smart-cep"
    ],
    "homepage": "https://github.com/otavio-araujo/filament-smart-cep",
    "support": {
        "issues": "https://github.com/otavio-araujo/filament-smart-cep/issues",
        "source": "https://github.com/otavio-araujo/filament-smart-cep"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Otávio Araújo",
            "email": "otavio_araujo@hotmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/forms": "^4.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "OtavioAraujo\\FilamentSmartCep\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OtavioAraujo\\FilamentSmartCep\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "OtavioAraujo\\FilamentSmartCep\\FilamentSmartCepServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
